# Copy this to .env and fill in the values from your Supabase project (Project Settings -> API).
# NEVER commit .env to source control.

PORT=4000
NODE_ENV=development

# From your Supabase project. The service role key bypasses RLS — keep secret, server-side only.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your_service_role_key...

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173
